# Get it at: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...your_gemini_key

# OpenAI (Optional/Opcional)
# Model: gpt-4o-mini
OPENAI_API_KEY=sk-proj-...your_openai_key

# Anthropic (Optional/Opcional)
# Model: claude-3-haiku
ANTHROPIC_API_KEY=sk-ant-api03-...your_anthropic_key

# Groq Cloud (Optional/Opcional)
# Model: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_...your_groq_key

# LM-Studio (Local via OpenAI-compatible endpoint)
# Model: e.g. "llama-3.1-8b-instruct" (depends on your LM-Studio model name)
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Optional if your server ignores auth:
LMSTUDIO_API_KEY=
LMSTUDIO_MODEL=

# Ollama (Local via OpenAI-compatible endpoint)
# Model: e.g. "llama3.1" (depends on your Ollama model name)
OLLAMA_BASE_URL=http://localhost:11434/v1
# Optional if your server ignores auth:
OLLAMA_API_KEY=
OLLAMA_MODEL=

# Active Provider / Provedor Ativo: [gemini, openai, anthropic, groq, lmstudio, ollama]
LLM_PROVIDER=gemini
